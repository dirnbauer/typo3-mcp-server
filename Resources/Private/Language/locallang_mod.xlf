    <header/>
    <body>
      <!-- Module registration -->
      <trans-unit id="mlang_tabs_tab">
        <source>MCP Server</source>
      </trans-unit>
      <trans-unit id="mlang_labels_tabdescr">
        <source>Access your Model Context Protocol (MCP) server endpoint and authentication tokens</source>
      </trans-unit>
      <trans-unit id="title">
        <source>MCP Server Configuration</source>
      </trans-unit>
      <trans-unit id="description">
        <source>Your personal MCP server endpoint for connecting external applications like Claude Desktop, VS Code, or other MCP-compatible clients.</source>
      </trans-unit>

      <!-- Extension configuration labels -->
      <trans-unit id="extconf.additionalReadOnlyTables">
        <source>Additional read-only tables: comma-separated list of non-workspace-capable tables to expose for reads via MCP (e.g. sys_file). These cannot be written through workspace tools.</source>
      </trans-unit>
      <trans-unit id="extconf.fileSandboxRoot">
        <source>MCP file sandbox root folder. Use a combined identifier such as "1:/mcp/". This defaults to fileadmin/mcp/ in the default storage.</source>
      </trans-unit>
      <trans-unit id="extconf.workspaceUploadSubfolders">
        <source>Store MCP uploads in workspace-specific subfolders below the sandbox root for safer draft handling.</source>
      </trans-unit>
      <trans-unit id="extconf.allowMcpTokenInQueryString">
        <source>Allow passing the MCP bearer token as a query parameter (insecure: URLs are logged by proxies). Use only for legacy clients; prefer the Authorization header.</source>
      </trans-unit>
      <trans-unit id="extconf.enableMcpAuthHeaderDiagnostic">
        <source>Enable the public ?test=auth diagnostic on the MCP endpoint (used by the backend connection check). Disable on hardened sites if you do not need it.</source>
      </trans-unit>
      <trans-unit id="extconf.localUnsafeMode">
        <source>Local development mode: relax workspace-only writes, non-workspace table blocking, and the file sandbox so MCP can edit live records and write anywhere in fileadmin. "auto" detects DDEV and the TYPO3 development context. User TSconfig options.mcpServer.localUnsafeMode can override this; options.mcpServer.strictSandbox or feature flag mcpServer.strictSandbox forces strict mode. NEVER enable unsafe mode on production.</source>
      </trans-unit>
      <trans-unit id="extconf.enforceCapabilityManifest">
        <source>Enforce the capability manifest (Configuration/Capabilities.yaml). Tools whose required capabilities are not declared/granted are rejected at call time. Disable only for debugging.</source>
      </trans-unit>

      <!-- Connection setup card -->
      <trans-unit id="connectionSetup.title">
        <source>MCP Connection Setup</source>
      </trans-unit>
      <trans-unit id="connectionSetup.description">
        <source>Choose your preferred method to connect MCP clients to this TYPO3 instance.</source>
      </trans-unit>

      <!-- Warnings -->
      <trans-unit id="warning.noWorkspace.title">
        <source>No workspace configured</source>
      </trans-unit>
      <trans-unit id="warning.noWorkspace.text">
        <source>All changes made through MCP are staged in a TYPO3 Workspace before publishing. One will be created automatically, but you should</source>
      </trans-unit>
      <trans-unit id="warning.noWorkspace.createLink">
        <source>create one manually</source>
      </trans-unit>
      <trans-unit id="warning.noWorkspace.suffix">
        <source>to control permissions and review workflow.</source>
      </trans-unit>
      <trans-unit id="warning.localhost.title">
        <source>Local/private network detected</source>
      </trans-unit>
      <trans-unit id="warning.localhost.text">
        <source>{url} resolves to a private network address. Most remote MCP clients (Claude Desktop, n8n cloud, manus) cannot reach this server from the internet.</source>
      </trans-unit>
      <trans-unit id="warning.localhost.worksLocally">
        <source>What works locally:</source>
      </trans-unit>
      <trans-unit id="warning.localhost.localTools">
        <source>The MCP Inspector (runs on your machine) and the Local Setup (TYPO3 CLI) tab. The Local Setup (mcp-remote) may also work since mcp-remote runs on your machine.</source>
      </trans-unit>
      <trans-unit id="warning.authHeader.title">
        <source>Authorization header issue detected</source>
      </trans-unit>
      <trans-unit id="warning.authHeader.text">
        <source>The MCP endpoint cannot receive Authorization headers. This prevents OAuth authentication from working.</source>
      </trans-unit>
      <trans-unit id="warning.authHeader.causes">
        <source>Common causes and solutions:</source>
      </trans-unit>
      <trans-unit id="warning.authHeader.apache">
        <source>Add to your .htaccess:</source>
      </trans-unit>
      <trans-unit id="warning.authHeader.basicAuth">
        <source>May conflict with OAuth headers. Consider IP-based restrictions instead.</source>
      </trans-unit>
      <trans-unit id="warning.authHeader.proxy">
        <source>Some proxies strip Authorization headers. Check your infrastructure settings.</source>
      </trans-unit>

      <!-- Main tabs -->
      <trans-unit id="tab.remoteSetup">
        <source>Client Setup</source>
      </trans-unit>
      <trans-unit id="tab.localMcpRemote">
        <source>Local Setup (mcp-remote)</source>
      </trans-unit>
      <trans-unit id="tab.localCli">
        <source>Local Setup (TYPO3 CLI)</source>
      </trans-unit>

