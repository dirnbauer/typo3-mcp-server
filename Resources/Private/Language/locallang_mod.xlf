      <!-- Cursor instructions -->
      <trans-unit id="cursor.title">
        <source>Cursor IDE Integration</source>
      </trans-unit>
      <trans-unit id="cursor.description">
        <source>Connect Cursor's AI chat through the local TYPO3 CLI MCP server:</source>
      </trans-unit>
      <trans-unit id="cursor.installButton">
        <source>Install in Cursor</source>
      </trans-unit>
      <trans-unit id="cursor.authReuseNote">
        <source>The install link uses local stdio and starts vendor/bin/typo3 mcp:server in this project. No OAuth token is needed.</source>
      </trans-unit>
      <trans-unit id="cursor.manualConfig">
        <source>Or add to your ~/.cursor/mcp.json manually:</source>
      </trans-unit>
      <trans-unit id="cursor.copyConfig">
        <source>Copy Configuration</source>
      </trans-unit>
      <trans-unit id="cursor.whatHappensNext">
        <source>What happens next:</source>
      </trans-unit>
      <trans-unit id="cursor.step1">
        <source>Cursor starts the TYPO3 CLI MCP server from this project</source>
      </trans-unit>
      <trans-unit id="cursor.step2">
        <source>The AI chat talks to the server over stdin/stdout</source>
      </trans-unit>
      <trans-unit id="cursor.step3">
        <source>TYPO3 tools are available without an extra OAuth flow</source>
      </trans-unit>
      <trans-unit id="cursor.step4">
        <source>MCP tools become available in Cursor's agent</source>
      </trans-unit>

      <!-- Claude Desktop instructions -->
      <trans-unit id="claude.title">
        <source>Claude Desktop Integration</source>
      </trans-unit>
      <trans-unit id="claude.description">
        <source>To connect Claude Desktop to this TYPO3 instance:</source>
      </trans-unit>
      <trans-unit id="claude.step1">
        <source>In Claude Desktop, go to Settings → Integrations</source>
      </trans-unit>
      <trans-unit id="claude.step2">
        <source>Click "Add Integration"</source>
      </trans-unit>
      <trans-unit id="claude.step3">
        <source>Enter Integration Name: {name}</source>
      </trans-unit>
      <trans-unit id="claude.step4">
        <source>Paste the Server URL: {url}</source>
      </trans-unit>
      <trans-unit id="claude.step5">
        <source>Claude Desktop will automatically handle OAuth authentication</source>
      </trans-unit>

      <!-- n8n instructions -->
      <trans-unit id="n8n.title">
        <source>n8n Integration</source>
      </trans-unit>
      <trans-unit id="n8n.description">
        <source>To configure your n8n MCP Client node:</source>
      </trans-unit>
      <trans-unit id="n8n.step1">
        <source>In n8n, add an MCP Client node to your workflow</source>
      </trans-unit>
      <trans-unit id="n8n.step2">
        <source>Set Endpoint to: {url}</source>
      </trans-unit>
      <trans-unit id="n8n.step3">
        <source>Set Server Transport to: HTTP Streamable</source>
      </trans-unit>
      <trans-unit id="n8n.step4">
        <source>Set Authentication to: Bearer Auth</source>
      </trans-unit>
      <trans-unit id="n8n.step5">
        <source>Create a token in the Active OAuth Tokens section (e.g. name it "n8n"), create a new credential and paste the token</source>
      </trans-unit>
      <trans-unit id="n8n.step6">
        <source>Select which tools to include or choose "All"</source>
      </trans-unit>

      <!-- manus instructions -->
      <trans-unit id="manus.title">
        <source>manus Integration</source>
      </trans-unit>
      <trans-unit id="manus.description">
        <source>To configure your manus MCP connection:</source>
      </trans-unit>
      <trans-unit id="manus.step1">
        <source>In manus, go to Connectors settings and add a connector</source>
      </trans-unit>
      <trans-unit id="manus.step2">
        <source>Set Server Name to: {name}</source>
      </trans-unit>
      <trans-unit id="manus.step3">
        <source>Set Transport to: HTTP</source>
      </trans-unit>
      <trans-unit id="manus.step4">
        <source>Set Server URL to: {url}</source>
      </trans-unit>
      <trans-unit id="manus.step5">
        <source>Create a token in the Active OAuth Tokens section (e.g. name it "manus")</source>
      </trans-unit>
      <trans-unit id="manus.step6">
        <source>Add a custom header "Authorization" with the value "Bearer YOUR_TOKEN" (use the token shown at creation)</source>
      </trans-unit>
      <trans-unit id="manus.step7">
        <source>Save your MCP configuration</source>
      </trans-unit>

