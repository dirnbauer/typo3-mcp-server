{
    "name": "hn/typo3-mcp-server",
    "type": "typo3-cms-extension",
    "description": "TYPO3 extension that provides a Model Context Protocol (MCP) server for interacting with TYPO3 pages and records",
    "license": "GPL-2.0-or-later",
    "homepage": "https://github.com/hauptsacheNet/typo3-mcp-server",
    "authors": [
        {
            "name": "Marco Pfeiffer",
            "email": "marco@hauptsache.net"
        }
    ],
    "require": {
        "php": ">=8.2.0",
        "logiscape/mcp-sdk-php": "^1.2",
        "typo3/cms-backend": "^13.4 || ^14.0",
        "typo3/cms-core": "^13.4 || ^14.0",
        "typo3/cms-workspaces": "^13.4 || ^14.0"
    },
    "require-dev": {
        "typo3/testing-framework": "^9.2.0",
        "typo3/cms-install": "^13.4 || ^14.0",
        "georgringer/news": "^14.0",
        "brianium/paratest": "^7.8.5",
        "phpstan/phpstan": "^2.1",
        "ssch/typo3-rector": "^3.0",
        "a9f/typo3-fractor": "^0.4",
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpat/phpat": "^0.12.3"
    },
    "autoload": {
        "psr-4": {
            "Hn\\McpServer\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hn\\McpServer\\Tests\\": "Tests/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "mcp_server"
        }
    },
    "scripts": {
        "setup": [
            "bash Build/setup-typo3.sh"
        ],
        "post-install-cmd": [
            "@setup"
        ],
        "post-update-cmd": [
            "@setup"
        ],
        "test": [
            "@test:unit",
            "@test:functional"
        ],
        "test:unit": [
            "phpunit -c Tests/UnitTests.xml"
        ],
        "test:functional": [
            "paratest -c phpunit.xml.dist"
        ],
        "test:llm": [
            "paratest -c Tests/Llm/phpunit-llm.xml"
        ],
        "phpstan": [
            "phpstan analyse --no-progress"
        ],
        "php-cs-fixer": [
            "php-cs-fixer fix --dry-run --diff"
        ],
        "php-cs-fixer:fix": [
            "php-cs-fixer fix"
        ],
        "rector": [
            "rector process --dry-run"
        ],
        "rector:fix": [
            "rector process"
        ],
        "fractor": [
            "fractor process --dry-run"
        ],
        "fractor:fix": [
            "fractor process"
        ]
    },
    "config": {
        "allow-plugins": {
            "a9f/fractor-extension-installer": true,
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        }
    }
}
